# ─── PartyKit (Online Multiplayer) ───────────────────────────────────────────
# 1. Run: npx partykit deploy
# 2. Sign in with GitHub when prompted
# 3. Copy the deployed URL and paste below (without https://)
# Example: tictactoe-pro.yourname.partykit.dev
VITE_PARTYKIT_HOST=tictactoe-pro.yourname.partykit.dev

# ─── Optional: Supabase (alternative backend) ────────────────────────────────
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON=your-anon-key
